{
  "name": "projet-blablabook",
  "version": "1.0.0",
  "description": "BlaBlaBook est une plateforme en ligne dédiée à la découverte et au partage de livres. Son objectif est de favoriser les échanges autour des ouvrages, et de créer une communauté autour de la littérature. BlaBlaBook se veut intuitif et facile d’utilisation.",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "data:fetch": "node app/database/fetchOpenLibrairy.js",
    "data:structure": "node app/database/structuredOpenLibrairy.js",
    "db:create": "node migrations/create-tables.js",
    "db:seed": "node migrations/seed-database.js",
    "db:reset": "npm run db:create && npm run db:seed",
    "db:init": "npm run data:fetch && npm run data:structure && npm run db:reset",
    "test": "node --test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/O-clock-Figueres/projet-blablabook.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/O-clock-Figueres/projet-blablabook/issues"
  },
  "homepage": "https://github.com/O-clock-Figueres/projet-blablabook#readme",
  "dependencies": {
    "argon2": "^0.44.0",
    "dotenv": "^17.2.3",
    "ejs": "^3.1.10",
    "express": "^5.2.1",
    "express-session": "^1.18.2",
    "http-status-codes": "^2.3.0",
    "joi": "^18.0.2",
    "nodemailer": "^7.0.12",
    "pg": "^8.17.1",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.7"
  },
  "devDependencies": {
    "nodemon": "^3.1.11",
    "sinon": "^21.0.1"
  }
}
