<%- include("partials/header.ejs") %>

  <main class="contact_page">
    <div class="contact_container">
      <h1>Contactez-nous</h1>
      <p>BlaBlaBook est une plateforme pour vous créée par nous ( Kéo, Maëva et Margaux ) ! Pour que vous puissez gérer
        votre propre bibliothèque numérique et l'emmener partout avec vous. Nous avons essayé de faire une plateforme
        complète pour vous mais peut-être que nous avons oublié des choses. Vous avez une idée, des suggestions, des
        recommandations ? N'hésitez pas à nous contacter ! Promis nous ne mangeons pas et nous essayerons de réponses à
        toutes vos attentes . Bien à vous ! </p>

      <% if (typeof success !=='undefined' && success) { %>
        <p class="success_message">
          <%= success %>
        </p>
        <% } %>

          <% if (typeof error !=='undefined' && error) { %>
            <p class="error_message">
              <%= error %>
            </p>
            <% } %>

              <form action="/contact" method="post" class="contact_form">
                <div class="form_group">
                  <label for="name">Nom</label>
                  <input type="text" id="name" name="name" value="<%= typeof name !== 'undefined' ? name : '' %>"
                    required>
                </div>
                <div class="form_group">
                  <label for="email">Email</label>
                  <input type="email" id="email" name="email" value="<%= typeof email !== 'undefined' ? email : '' %>"
                    required>
                </div>
                <div class="form_group">
                  <label for="message">Message</label>
                  <textarea id="message" name="message" rows="5" minlength="20"
                    required><%= typeof message !== 'undefined' ? message : '' %></textarea>
                </div>
                <button type="submit" class="primary">Envoyer</button>
              </form>
    </div>
  </main>

  <%- include("partials/footer.ejs") %>