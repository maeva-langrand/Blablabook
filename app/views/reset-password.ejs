<%- include("partials/header.ejs", { needsPasswordValidation: true }) %>
<main class="forgot_password_page">
  <div class="forgot_password_container">
    <h1>Réinitialiser le mot de passe</h1>
    <p>Choisissez un nouveau mot de passe pour votre compte.</p>

    <% if (typeof success !== 'undefined' && success) { %> 
      <p class="forgot_password_success"><%= success %></p>
    <% } %>
    
    <% if (typeof error !== 'undefined' && error) { %>
      <p class="forgot_password_error"><%= error %></p>
    <% } %>

    <p id="reset-client-error" class="forgot_password_error" style="display:none"></p>

    <form action="/reset-password" method="post" class="forgot_password_form">
      <input type="hidden" name="token" value="<%= typeof token !== 'undefined' ? token : '' %>">

      <div class="form_group">
        <label for="password">Nouveau mot de passe</label>
        <input type="password" id="password" name="password" required autocomplete="new-password">
        <small id="password-error" class="password_validation_error"></small>
      </div>

      <div class="form_group">
        <label for="verify_password">Confirmer le mot de passe</label>
        <input type="password" id="verify_password" name="verify_password" required autocomplete="new-password">
        <small id="confirm-error" class="password_validation_error"></small>
      </div>

      <button type="submit" class="primary">Mettre à jour le mot de passe</button>
    </form>
  </div>
</main>

<script src="/js/reset-password-validation.js" defer></script>

<%- include("partials/footer.ejs") %>
