
<h1 class="section_<%= type %>_h1">
    <%= type==='login' ? 'Connexion' : 'Inscription' %>
</h1>

<section class="section_<%= type %>" id="<%=type%>-section">

    <%if (type==='login' ) { %>
        <div class="left_section_login">
            <h2 class="section_login_h2">Content de te revoir</h2>
            <img src="/img/Livre-random.jpg" alt="Content de te revoir" class="section_login_img">
            <a href="" class="section_<%= type %>_switch secondary">Inscrivez-vous</a>

        </div>

        <div class="right_section_login">
            <h2 class="section_login_h2"> Se connecter </h2>
            <form action="/login" method="post" class="right_section_login_form">
                <div class="inputbox">
                    <label for="login_pseudo">Pseudo</label>
                    <input type="text" id="login_pseudo" name="username" placeholder="Entrez votre pseudo" autocomplete="username" value="<%= typeof username !== 'undefined' ? username : '' %>" required>
                </div>

<!--                 <div class="inputbox">
                    <label for="login_mail">Email</label>
                    <input type="text" id="login_mail" name="email" placeholder="Entrez votre mail" required>
                </div> -->

                <div class="inputbox">
                    <label for="login_password">Mot de passe</label>
                    <input type="password" id="login_password" name="password" placeholder="Entrez le mot de passe" autocomplete="current-password" required>
                </div>

                <div class="checkbox">
                    <input type="checkbox" id="remember">
                    <label for="remember">se souvenir de moi</label>
                </div>

                <div class="checkbox">
                    <input type="checkbox">
                    <a href="/forgot-password">Mot de passe oublié ?</a>
                </div>

                <button type="submit" class="section_login_button primary">Se connecter</button>

            </form>
        </div>

    <% } else if (type === 'register') { %>

            <div class="left_section_register">
                <h2 class="section_register_h2">S'inscrire</h2>
                <form action="/register" method="post" class="section_register_form">
                    <div class="inputbox">
                        <label for="register_pseudo">Pseudo</label>
                        <input type="text" id="register_pseudo" name="username" placeholder="Entrez votre pseudo" autocomplete="username" value="<%= typeof username !== 'undefined' ? username : '' %>" required>
                    </div>

                    <div class="inputbox">
                        <label for="register_mail">Email</label>
                        <input type="email" id="register_mail" name="email" placeholder="Entrez votre Email" autocomplete="email" value="<%= typeof email !== 'undefined' ? email : '' %>" required>

                    </div>
                    <div class="inputbox">
                        <label for="register_password">mot de passe</label>
                        <input type="password" id="register_password" name="password" placeholder="Entrez un mot de passe" autocomplete="new-password" required>

                    </div>
                    <div class="inputbox">
                        <label for="register_verify_password">Vérification du mot de passe</label>
                        <input type="password" id="register_verify_password" name="verify_password" placeholder="Entrez le mot de passe" autocomplete="new-password" required>

                    </div>

                    <button type="submit" class="section_register_button primary">S'inscrire</button>
                </form>
            </div>

            <div class="right_section_register">
                <h2 class="section_register_h2">Bienvenue dans cette nouvelle aventure</h2>
                <img src="/img/Livre-random.jpg" alt="Content de te revoir" class="section_register_img">
                <a href="" class="section_<%= type %>_switch secondary">Connectez-vous</a>
            </div>

    <% } %>

</section>